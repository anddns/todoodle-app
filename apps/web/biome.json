{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "root": false,
  "extends": "//",
  "javascript": {
    "jsxRuntime": "transparent",
    "formatter": {
      "jsxQuoteStyle": "double"
    }
  },
  "linter": {
    "rules": {
      "correctness": {
        "useExhaustiveDependencies": "warn"
      },
      "a11y": {
        "useAltText": "error",
        "useAriaPropsForRole": "error"
      }
    }
  }
}
